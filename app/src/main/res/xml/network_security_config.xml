<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Deny cleartext app-wide; JNN POSTs are HTTPS-only. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!--
      Certificate pinning intentionally omitted: Google rotates youtube.com leaf
      certs frequently and pins to a broad CA set; a stale pin would silently break
      minting with no telemetry. cleartext-deny + instanceFollowRedirects=false
      provide the transport guarantees we need.
    -->
</network-security-config>
